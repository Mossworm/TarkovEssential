@page "/"
@page "/maps"
@inject LocalizationService LocalizationService
@inject NativeWebViewService NativeWebViewService
@layout AppLayout
@implements IDisposable

@code {
    [CascadingParameter(Name="AppLayout")]
    public AppLayout AppLayout { get; set; }

    protected override void OnInitialized()
    {
        NativeWebViewService.SetMapsVisible(true);
    }

    protected override void OnAfterRender(bool firstRender)
    {
        base.OnAfterRender(firstRender);
        if (firstRender)
        {
            AppLayout.SetTitle(LocalizationService.GetString("Maps"));
        }
    }

    public void Dispose()
    {
        NativeWebViewService.SetMapsVisible(false);
    }
}
